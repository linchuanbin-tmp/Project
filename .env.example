# ==================================================
# Agent Platform 环境配置模板
# 复制此文件为 .env 并填入实际值
# ==================================================

# ==================================================
# Agent Platform 环境配置
# 老师/用户：直接复制此文件为 .env 即可运行
#    cp .env.example .env
# ==================================================

DB_HOST=mysql
DB_PORT=3306
DB_NAME=agent_platform
DB_USERNAME=root
DB_PASSWORD=123456

REDIS_HOST=redis
REDIS_PORT=6379

USER_SERVICE_URI=http://user-service:8081
TASK_SERVICE_URI=http://task-service:8082
TASK_SERVICE_WS_URI=ws://task-service:8082
TOOL_SERVICE_URI=http://tool-agent:8083
RAG_SERVICE_URI=http://rag-agent:8085
GATEWAY_URL=http://gateway-service:8080

FRONTEND_PORT=3000
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
TASK_SERVICE_PORT=8082
TOOL_AGENT_PORT=8083
RAG_AGENT_PORT=8085
MYSQL_EXPOSED_PORT=3306
REDIS_EXPOSED_PORT=6379

JWT_SECRET=change-this-in-production-must-be-at-least-32-chars-long!!
JWT_EXPIRATION=86400000

# ── AI API Keys ─────────────────────────────────────
# 替换为你的 API Key（或从 .env 复制）
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://maas-api.cn-huabei-1.xf-yun.com/v2
DEEPSEEK_MODEL=xopdeepseekv32
DEEPSEEK_OFFICIAL_API_KEY=your_deepseek_official_api_key
AMAP_KEY=your_amap_key

# ── Resend Email ────────────────────────────────────
RESEND_API_KEY=your_resend_api_key

# ── MinIO / Milvus ──────────────────────────────────
RAG_VECTOR_STORE_PROVIDER=milvus
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_TOKEN=
MILVUS_GRPC_PORT=19530
MILVUS_HTTP_PORT=9091
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://minio:9000
RAG_MILVUS_COLLECTION=rag_document_chunks_bge_m3
RAG_VECTOR_METRIC=COSINE
RAG_VECTOR_INDEX=HNSW
RAG_STORAGE_PROVIDER=minio
RAG_MINIO_ENDPOINT=http://minio:9000
RAG_DOCUMENT_BUCKET=rag-documents

# ── Embedding (本地 BGE-M3 via rag-worker) ──────────
RAG_EMBEDDING_ACTIVE_PROFILE=local-bge-m3
RAG_EMBEDDING_PROVIDER=http
RAG_EMBEDDING_ENDPOINT=http://rag-worker:8091/embed
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_EMBEDDING_DIM=1024
RAG_EMBEDDING_TIMEOUT_MS=30000
RAG_LOCAL_EMBEDDING_ENDPOINT=http://rag-worker:8091/embed
RAG_LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
RAG_LOCAL_EMBEDDING_DIM=1024
RAG_LOCAL_EMBEDDING_TIMEOUT_MS=30000
RAG_LOCAL_MILVUS_COLLECTION=rag_document_chunks_bge_m3
RAG_QWEN_EMBEDDING_ENDPOINT=
RAG_QWEN_EMBEDDING_API_KEY=
RAG_QWEN_EMBEDDING_MODEL=text-embedding-v4
RAG_QWEN_EMBEDDING_DIM=1024
RAG_QWEN_EMBEDDING_TIMEOUT_MS=30000
RAG_QWEN_MILVUS_COLLECTION=rag_document_chunks_qwen_v4_1024

# ── RAG Worker ──────────────────────────────────────
RAG_WORKER_PORT=8091
RAG_WORKER_MODEL=BAAI/bge-m3
RAG_WORKER_DEVICE=
RAG_WORKER_NORMALIZE=true
RAG_WORKER_MAX_BATCH_SIZE=32
HF_DOWNLOAD=1
RAG_CHUNK_SIZE_TOKENS=700
RAG_CHUNK_OVERLAP_TOKENS=100

# ── RAG LLM ─────────────────────────────────────────
RAG_LLM_PROVIDER=http
RAG_LLM_API_KEY=your_rag_llm_api_key
RAG_LLM_BASE_URL=https://maas-api.cn-huabei-1.xf-yun.com/v2
RAG_LLM_MODEL=xopdeepseekv32
RAG_LLM_TIMEOUT_MS=30000
RAG_LLM_TEMPERATURE=0.2
RAG_LLM_MAX_TOKENS=1200
